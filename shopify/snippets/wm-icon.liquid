{%- comment -%}
  Whey Maker inline SVG icons.
  Usage: {% render 'wm-icon', icon: 'star', size: 14 %}
{%- endcomment -%}
{%- assign s = size | default: 16 -%}
{%- case icon -%}
  {%- when 'star' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5l2 4.2 4.6.6-3.3 3.2.8 4.6L8 11.9l-4.1 2.2.8-4.6L1.4 6.3l4.6-.6z"/></svg>
  {%- when 'cart' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 4h2l2.5 11h11l2-8H6"/><circle cx="9" cy="20" r="1.2"/><circle cx="17" cy="20" r="1.2"/></svg>
  {%- when 'search' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="11" cy="11" r="6.5"/><path d="M20 20l-4-4"/></svg>
  {%- when 'plus' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M8 3v10M3 8h10"/></svg>
  {%- when 'minus' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M3 8h10"/></svg>
  {%- when 'leaf' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 4c-9 0-14 5-14 12 0 2 .5 3 1 4"/><path d="M20 4c0 7-4 13-13 15"/></svg>
  {%- when 'flask' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6M10 3v6l-5 9a2 2 0 002 3h10a2 2 0 002-3l-5-9V3"/><path d="M7.5 14h9"/></svg>
  {%- when 'shield' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/><path d="M8.5 12l2.5 2.5L15.5 10"/></svg>
  {%- when 'truck' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6h12v10H2zM14 10h5l3 3v3h-8"/><circle cx="6" cy="17" r="1.5"/><circle cx="18" cy="17" r="1.5"/></svg>
  {%- when 'zoom' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="10.5" cy="10.5" r="6.5"/><path d="M20 20l-4.2-4.2M10.5 7.5v6M7.5 10.5h6"/></svg>
  {%- when 'cross' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M6.7 1h2.6v3.6H13V7H9.3v8H6.7V7H3V4.6h3.7z"/></svg>
{%- endcase -%}
