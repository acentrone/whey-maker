{%- comment -%} Whey Maker — "A meal in a shake" + single labeled diagram image. {%- endcomment -%}
{% render 'wm-assets' %}

{%- if section.settings.diagram_image -%}
  {%- assign diagram_src = section.settings.diagram_image | image_url: width: 1450 -%}
{%- else -%}
  {%- assign diagram_src = 'shake-stack-full.jpg' | asset_url -%}
{%- endif -%}

<div class="wm-pdp">
  <section class="wmk-meal-section">
    <div class="wmk-bound" style="padding-top:120px;padding-bottom:120px">
      <div class="wmk-meal">
        <div>
          <h2 class="wmk-display"><span class="wmk-pink">{{ section.settings.title_pink }}</span><br>{{ section.settings.title_rest }}</h2>
          <div class="wmk-lede">{{ section.settings.body }}</div>
          <div class="wmk-macro-tiles wmk-macro-tiles-lg">
            <div class="wmk-tile"><div class="wmk-n">{{ section.settings.macro1_value }}</div><div class="wmk-l">{{ section.settings.macro1_label }}</div></div>
            <div class="wmk-tile"><div class="wmk-n">{{ section.settings.macro2_value }}</div><div class="wmk-l">{{ section.settings.macro2_label }}</div></div>
            <div class="wmk-tile"><div class="wmk-n">{{ section.settings.macro3_value }}</div><div class="wmk-l">{{ section.settings.macro3_label }}</div></div>
          </div>
        </div>
        <div class="wmk-shake-solo">
          <img src="{{ diagram_src }}" alt="{{ section.settings.diagram_alt | escape }}" loading="lazy">
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "WM · Meal in a shake",
  "tag": "section",
  "class": "wm-section",
  "settings": [
    { "type": "text", "id": "title_pink", "label": "Headline (pink)", "default": "A meal" },
    { "type": "text", "id": "title_rest", "label": "Headline (black)", "default": "in a shake." },
    { "type": "richtext", "id": "body", "label": "Paragraph", "default": "<p>Typical “protein shakes” leave an athlete 800 calories short of what they need to build the body they desire. They can drink protein all day, but without the supporting carbs and fats in the correct ratios providing significantly high calories, they will never grow. Whey Maker is built to be a full meal in a bag that is convenient and quick to consume on the go. <strong>Seven organic carb sources, the three highest-quality forms of protein, organic fruits, organic vegetables, and digestive enzymes.</strong> Everything an athlete needs to gain lean muscle inside of one bag.</p>" },
    { "type": "header", "content": "Macro boxes" },
    { "type": "text", "id": "macro1_value", "label": "Box 1 number", "default": "1250" },
    { "type": "text", "id": "macro1_label", "label": "Box 1 label", "default": "Calories" },
    { "type": "text", "id": "macro2_value", "label": "Box 2 number", "default": "60g" },
    { "type": "text", "id": "macro2_label", "label": "Box 2 label", "default": "Protein" },
    { "type": "text", "id": "macro3_value", "label": "Box 3 number", "default": "238g" },
    { "type": "text", "id": "macro3_label", "label": "Box 3 label", "default": "Organic Carbs" },
    { "type": "header", "content": "Diagram image" },
    { "type": "image_picker", "id": "diagram_image", "label": "Labeled diagram (defaults to shake-stack-full.jpg)" },
    { "type": "text", "id": "diagram_alt", "label": "Diagram alt", "default": "Vanilla Buttercream — a tall glass layered with every Whey Maker ingredient, labeled" }
  ],
  "presets": [{ "name": "WM · Meal in a shake" }]
}
{% endschema %}
